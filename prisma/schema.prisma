generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model DefaultPreference {
  notificationType String  @map("notification_type")
  channel          String
  enabled          Boolean

  @@id([notificationType, channel])
  @@map("default_preferences")
}

model UserPreferenceOverride {
  userId           String   @map("user_id")
  notificationType String   @map("notification_type")
  channel          String
  enabled          Boolean
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@id([userId, notificationType, channel])
  @@index([userId])
  @@map("user_preference_overrides")
}

model UserQuietHours {
  userId       String   @id @map("user_id")
  startMinutes Int      @map("start_minutes")
  endMinutes   Int      @map("end_minutes")
  timezone     String
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("user_quiet_hours")
}

model GlobalPolicy {
  id               String   @id @default(uuid()) @db.Uuid
  notificationType String   @map("notification_type")
  region           String
  channel          String?
  action           String   @default("deny")
  reasonCode       String   @default("blocked_by_global_policy") @map("reason_code")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([notificationType, region])
  @@map("global_policies")
}
